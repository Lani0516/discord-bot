{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "Multi-purpose Discord bot with admin, fun, AI chat, and Minecraft status",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "deploy": "bun src/deploy-commands.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test tests/database.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.0",
    "minecraft-server-util": "^5.4.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "~5.7"
  }
}
